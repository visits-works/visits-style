{
  "name": "visits-style",
  "repository": "https://github.com/visits-works/visits-style",
  "homepage": "https://github.com/visits-works/visits-style",
  "version": "2.1.5",
  "description": "VISITS Technologiesのreactデザインコンポーネント",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.es.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    },
    "./lib.css": "./dist/lib.css"
  },
  "license": "Apache-2.0",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.0"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.18",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "scripts": {
    "build": "vite build",
    "lint": "eslint 'src/**/*.{ts,tsx}' && tsc --noEmit",
    "test": "vitest",
    "dev": "STORYBOOK=true storybook dev -p 9000",
    "storybook:build": "STORYBOOK=true storybook build -c .storybook -o .out --disable-telemetry",
    "storybook:deploy": "bun storybook:build && gh-pages -d .out"
  },
  "devDependencies": {
    "@storybook/addon-docs": "10.2.10",
    "@storybook/addon-links": "10.2.10",
    "@storybook/react-vite": "10.2.10",
    "@storybook/testing-library": "^0.2.2",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.16.0",
    "gh-pages": "^6.3.0",
    "happy-dom": "^20.6.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "10.2.10",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-externalize-deps": "^0.10.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
