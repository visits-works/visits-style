{
  "name": "visits-style",
  "repository": "https://github.com/visits-works/visits-style",
  "homepage": "https://github.com/visits-works/visits-style",
  "version": "2.1.2",
  "description": "VISITS Technologiesのreactデザインコンポーネント",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./lib.css": "./dist/lib.css"
  },
  "license": "Apache-2.0",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">19.1.1",
    "react-dom": ">19.1.1",
    "tailwindcss": ">4.1.13"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.16",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "scripts": {
    "build": "vite build",
    "lint": "eslint 'src/**/*.{ts,tsx}' && tsc --noEmit",
    "test": "vitest",
    "dev": "STORYBOOK=true storybook dev -p 9000",
    "storybook:build": "STORYBOOK=true storybook build -c .storybook -o .out --disable-telemetry",
    "storybook:deploy": "bun storybook:build && gh-pages -d .out"
  },
  "devDependencies": {
    "@storybook/addon-docs": "9.1.5",
    "@storybook/addon-links": "9.1.5",
    "@storybook/react-vite": "9.1.5",
    "@storybook/testing-library": "^0.2.2",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.34.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-testing-library": "^7.6.8",
    "gh-pages": "^6.3.0",
    "happy-dom": "^18.0.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "storybook": "9.1.5",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-externalize-deps": "^0.9.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
